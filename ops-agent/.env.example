# OpenAI 兼容 API（Agno 默认）
OPENAI_API_KEY=
# 若使用中转，可设置：
# OPENAI_API_BASE=

# Mem0 托管 API（未设置时使用本地内存后端，见 docs/OPERATIONS.md）
MEM0_API_KEY=

# Neo4j + Graphiti（阶段 b，只读检索；需 pip install -e ".[graphiti]"）
# NEO4J_URI=bolt://127.0.0.1:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# Graphiti 检索参数（可选）
# OPS_GRAPHITI_SEARCH_TIMEOUT_SEC=20
# OPS_GRAPHITI_MAX_RESULTS=12
# OPS_GRAPHITI_BFS_MAX_DEPTH=2

# 无 Neo4j 或超时时的 JSONL 降级（每行 {"group_id":"...","text":"..."}）
# OPS_KNOWLEDGE_FALLBACK_PATH=docs/examples/knowledge_fallback.example.jsonl

# Hindsight 存储路径（默认 data/hindsight.jsonl）
# OPS_HISTORICAL_PATH=data/hindsight.jsonl

# 退出 CLI 时 AsyncReview 复盘（默认开启）
# OPS_ASYNC_REVIEW_ON_EXIT=1
# OPS_ASYNC_REVIEW_MODEL=gpt-4o-mini

# ② handoff 清单（ops-knowledge manifest 生成，可选）
# OPS_HANDOFF_MANIFEST_PATH=D:/path/handbook_handoff.json

# 交付规则 JSON（check_delivery_text），可选；示例见 data/golden_rules.example.json
# OPS_GOLDEN_RULES_PATH=data/golden_rules.example.json

# MCP 探针 JSON（fetch_ops_probe_context），可选；默认使用包内 resources
# OPS_MCP_PROBE_FIXTURE_PATH=D:/path/custom_probe.json

# ② forge 导出的 Agent 配方（system_prompt / enabled_tools / handbook_version），可选
# OPS_AGENT_MANIFEST_PATH=D:/Coding/ops-stack/pipeline-demo/out/agent_config.json

# 供 ops-knowledge / doctor 定位 ① schema（可选；默认目录名见 ops-stack/ops-stack.toml）
# VIDEO_RAW_INGEST_ROOT=D:/Coding/ops-stack/video-raw-ingest
