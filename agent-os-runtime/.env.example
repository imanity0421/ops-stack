# OpenAI 兼容 API（Agno 默认）
OPENAI_API_KEY=
# 使用 4zapi 等中转时必填；不填则请求官方 https://api.openai.com ，中转 key 会 401
# 示例（以 4zapi 控制台文档为准）：
# OPENAI_API_BASE=https://4zapi.com/v1

# Mem0 托管 API（未设置时使用本地内存后端，见 docs/OPERATIONS.md）
MEM0_API_KEY=

# Neo4j + Graphiti（阶段 b，只读检索；需 pip install -e ".[graphiti]"）
# NEO4J_URI=bolt://127.0.0.1:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# Graphiti 检索参数（可选）
# AGENT_OS_GRAPHITI_SEARCH_TIMEOUT_SEC=20
# AGENT_OS_GRAPHITI_MAX_RESULTS=12
# AGENT_OS_GRAPHITI_BFS_MAX_DEPTH=2
# Graphiti 权限持久化文件（默认 data/graphiti_entitlements.json）
# AGENT_OS_GRAPHITI_ENTITLEMENTS_PATH=data/graphiti_entitlements.json
# Graphiti 权限变更审计日志（JSONL，默认 data/graphiti_entitlements_audit.jsonl）
# AGENT_OS_GRAPHITI_ENTITLEMENTS_AUDIT_PATH=data/graphiti_entitlements_audit.jsonl
# Graphiti 权限缓存 TTL（秒）；文件 mtime/env 变化会立即重载
# AGENT_OS_GRAPHITI_ENTITLEMENTS_CACHE_TTL_SEC=2
# Graphiti 权限文件/审计日志写入锁超时（秒）
# AGENT_OS_GRAPHITI_FILE_LOCK_TIMEOUT_SEC=5
# 审计日志滚动切分（bytes）与保留策略
# AGENT_OS_GRAPHITI_ENTITLEMENTS_AUDIT_MAX_BYTES=2097152
# AGENT_OS_GRAPHITI_ENTITLEMENTS_AUDIT_MAX_FILES=10
# AGENT_OS_GRAPHITI_ENTITLEMENTS_AUDIT_RETENTION_DAYS=30
# 兼容旧配置：仍支持 env 直接授权（仅在持久化文件未命中时兜底）
# AGENT_OS_GRAPHITI_ALLOWED_SKILL_IDS=default_agent,short_video
# AGENT_OS_GRAPHITI_CLIENT_ENTITLEMENTS_JSON={"acme":["short_video"]}

# 无 Neo4j 或超时时的 JSONL 降级（每行 {"group_id":"...","text":"..."}）
# AGENT_OS_KNOWLEDGE_FALLBACK_PATH=docs/examples/knowledge_fallback.example.jsonl

# Hindsight 存储路径（默认 data/hindsight.jsonl）
# AGENT_OS_HISTORICAL_PATH=data/hindsight.jsonl
# 是否启用 Hindsight（默认 1）
# AGENT_OS_ENABLE_HINDSIGHT=1

# 退出 CLI 时 AsyncReview 复盘（默认开启）
# AGENT_OS_ASYNC_REVIEW_ON_EXIT=1
# AGENT_OS_ASYNC_REVIEW_MODEL=gpt-4o-mini

# 是否允许 Agent 写入 Mem0（record_client_fact / record_client_preference），默认 1
# AGENT_OS_ENABLE_MEM0_LEARNING=1

# 参考案例库（Asset Store / LanceDB，可选）
# 是否启用 Asset Store（默认 0）
# AGENT_OS_ENABLE_ASSET_STORE=0
# LanceDB 目录路径（默认 data/asset_store.lancedb）
# AGENT_OS_ASSET_STORE_PATH=data/asset_store.lancedb
# 近似去重：特征向量 L2 低于该值视为同案（不设置则仅强指纹去重）
# AGENT_OS_ASSET_NEAR_DEDUP_L2_MAX=0.18
# 每 skill 硬合规：目录下 sample_skill.json 等，格式同 AGENT_OS_GOLDEN_RULES_PATH
# AGENT_OS_SKILL_COMPLIANCE_DIR=D:/path/compliance_rules

# ② handoff 清单（ops-knowledge manifest 生成，可选）
# AGENT_OS_HANDOFF_MANIFEST_PATH=D:/path/handbook_handoff.json

# 交付规则 JSON（check_delivery_text），可选；示例见 data/golden_rules.example.json
# AGENT_OS_GOLDEN_RULES_PATH=data/golden_rules.example.json

# MCP 探针 JSON（fetch_probe_context），可选；默认使用包内 resources
# AGENT_OS_MCP_PROBE_FIXTURE_PATH=D:/path/custom_probe.json

# Skill 配方目录：扫描 ``*.json``，文件名为 skill_id（如 default_agent.json）。未设置时使用包内置配方。
# 可将 ② forge 的 export-manifest 输出复制为 ``<目录>/default_agent.json``。
# AGENT_OS_MANIFEST_DIR=D:/Coding/ops-stack/pipeline-demo/out/skill_manifests

# 未显式传 --skill / skill_id 时的默认 skill（须存在于注册表）
# AGENT_OS_DEFAULT_SKILL_ID=default_agent
# 允许动态加载的技能子包（逗号分隔，仅 [a-zA-Z0-9_]+）；对应 ``agent_os.agent.skills.<name>``。空=不加载任何技能包。
# 开发/测试 sample_skill 时需包含：sample_skill
# AGENT_OS_LOADABLE_SKILL_PACKAGES=sample_skill

# Agno 会话/运行落库（P0-2）；默认 1
# AGENT_OS_ENABLE_SESSION_DB=1
# 单机 Sqlite 路径；多机时改用 AGENT_OS_SESSION_DB_URL 共享后端
# AGENT_OS_SESSION_DB_PATH=data/agno_session.db
# 可选；优先于路径：sqlite: / postgresql: / redis: / 无 scheme 的本地路径字符串
# AGENT_OS_SESSION_DB_URL=
# 将最近 N 条拼入模型上文（0=仅落库不拼上下文），默认 20
# AGENT_OS_SESSION_HISTORY_MAX_MESSAGES=20
# ContextBuilder 自动预取总开关，默认 1
# AGENT_OS_CONTEXT_AUTO_RETRIEVE=1
# 自动预取策略：keywords / always / manual，默认 keywords
# AGENT_OS_CONTEXT_AUTO_RETRIEVE_MODE=keywords
# keywords 策略触发词（逗号分隔）
# AGENT_OS_CONTEXT_AUTO_RETRIEVE_KEYWORDS=方案,策略,计划,规划,交付,文案,脚本,复盘,总结,分析,撰写,设计,架构,迭代,研发,优化
# 有 task summary 时 recent history 收紧到该值（0=不收紧），默认 12
# AGENT_OS_SESSION_HISTORY_CAP_WHEN_TASK_SUMMARY=12
# ContextBuilder 字符预算总上限（0=关闭块级预算），默认 24000
# AGENT_OS_CONTEXT_MAX_CHARS=24000
# 估算最终 prompt token 总量（缺 tiktoken 时静默降级），默认 1
# AGENT_OS_CONTEXT_ESTIMATE_TOKENS=1
# recent_history 中历史工具结果合计最多保留多少字符（0=不做聚合预算），默认 2000
# AGENT_OS_CONTEXT_TOOL_OUTPUTS_TOTAL_MAX_CHARS=2000
# 默认关闭：启用结构化硬总预算省略，永不裁 current user message
# AGENT_OS_CONTEXT_HARD_BUDGET=0
# 默认开启：超过 ContextBuilder 总预算时自动执行确定性低优先级裁切自救
# AGENT_OS_CONTEXT_SELF_HEAL_OVER_BUDGET=1
# 输出 ContextBuilder 块级 trace 日志（不进 prompt），默认 0
# AGENT_OS_CONTEXT_TRACE_LOG=0

# 系统「宪法·冲突解决序」（P1-3），默认 1
# AGENT_OS_ENABLE_CONSTITUTIONAL=1

# P1.5 认知稳定性：临时运行时元数据（只进 prompt，不落长期记忆），默认 1
# AGENT_OS_ENABLE_EPHEMERAL_METADATA=1
# AGENT_OS_TIMEZONE=Asia/Shanghai
# P1.5 Memory Policy：拒绝玩笑/临时/模糊内容写入长期记忆，默认 1；mode=reject|warn
# AGENT_OS_ENABLE_MEMORY_POLICY=1
# AGENT_OS_MEMORY_POLICY_MODE=reject
# P1.5 Temporal Grounding：检索结果带 [记录于 ...]，默认 1
# AGENT_OS_ENABLE_TEMPORAL_GROUNDING=1
# P1.5 Task-aware Working Memory：同一 session 内自动维护 task_id + task summary（首批默认关闭）
# AGENT_OS_ENABLE_TASK_MEMORY=0
# AGENT_OS_TASK_MEMORY_DB_PATH=data/task_memory.db
# AGENT_OS_TASK_SUMMARY_MAX_CHARS=800

# POST /ingest → asset_store 时是否调用 LLM 裁判/特征（开发可关）
# AGENT_OS_INGEST_ALLOW_LLM=1

# Web 演示默认 skill（可选；与对话请求的 skill_id 二选一优先级见 examples/web_chat_fastapi.py）
# AGENT_OS_WEB_SKILL_ID=sample_skill
# Web 内网管理接口（Graphiti 权限增删改查）；默认关闭。仅在本机访问时建议开启
# AGENT_OS_WEB_ENABLE_ADMIN_API=0
# Web 管理接口鉴权 token（至少设置一个）
# AGENT_OS_WEB_ADMIN_API_TOKEN=replace_me
# AGENT_OS_WEB_ADMIN_API_TOKENS=token_a,token_b
# Web 管理接口允许来源 host（逗号分隔）
# AGENT_OS_WEB_ADMIN_ALLOWED_HOSTS=127.0.0.1,::1,localhost
# Web 管理接口幂等键去重（网络重试防重复写）
# AGENT_OS_WEB_ADMIN_IDEMPOTENCY_ENABLED=1
# AGENT_OS_WEB_ADMIN_IDEMPOTENCY_TTL_SEC=600

# 供 ops-knowledge / doctor 定位 ① schema（可选；默认目录名见 ops-stack/ops-stack.toml）
# VIDEO_RAW_INGEST_ROOT=D:/Coding/ops-stack/video-raw-ingest
